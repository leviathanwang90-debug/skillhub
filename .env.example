# Feishu App
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
NEXT_PUBLIC_FEISHU_APP_ID=your_feishu_app_id

# Session encryption key (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-a-random-64-char-hex-string

# Aliyun OSS
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET=your_bucket_name
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_SKILL_PREFIX=skillhub/

# Initial admin feishu open_ids (comma separated)
INITIAL_ADMIN_OPEN_IDS=
